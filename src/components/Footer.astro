---
const year = new Date().getFullYear();
---
<footer class="border-t border-(--color-border) mt-16">
  <div class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-3 px-4 py-8 text-sm text-(--color-muted) sm:flex-row sm:px-6">
    <p>&copy; {year} Muhammed Shah. All rights reserved.</p>
    <div class="flex items-center gap-4">
      <a
        href="mailto:muhammed.muzzammilshah@gmail.com"
        aria-label="Email"
        class="flex h-5 w-5 items-center justify-center hover:text-(--color-accent) transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="m3.5 6.8 7.6 5.7a1.6 1.6 0 0 0 1.8 0l7.6-5.7" />
        </svg>
      </a>
      <a
        href="https://x.com/MoShahx07"
        aria-label="X (Twitter)"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-5 w-5 items-center justify-center hover:text-(--color-accent) transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
          <path d="M18.9 3H22l-7.2 8.2L22.6 21h-6.2l-5-6.4L5.6 21H2.4l7.7-8.8L2 3h6.3l4.5 5.9L18.9 3Zm-2.2 16h1.7L7.4 5h-1.8l11.1 14Z" />
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/muhammed-shah/"
        aria-label="LinkedIn"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-5 w-5 items-center justify-center hover:text-(--color-accent) transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
          <path d="M6.94 6.5a1.94 1.94 0 1 1 0-3.88 1.94 1.94 0 0 1 0 3.88ZM5 8.75h3.88V21H5V8.75Zm6.5 0h3.72v1.68h.05c.52-.98 1.79-2 3.68-2 3.94 0 4.67 2.59 4.67 5.96V21h-3.88v-5.6c0-1.34-.02-3.06-1.87-3.06-1.87 0-2.16 1.46-2.16 2.96V21H11.5V8.75Z" />
        </svg>
      </a>
      <a
        href="https://muhammedshah.com/"
        aria-label="Personal website"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-5 w-5 items-center justify-center hover:text-(--color-accent) transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
          <circle cx="12" cy="12" r="9" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M12 3a13.6 13.6 0 0 1 0 18 13.6 13.6 0 0 1 0-18Z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
