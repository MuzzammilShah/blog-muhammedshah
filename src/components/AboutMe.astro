---
import { Image } from 'astro:assets';
import profile from '../assets/about/profile.jpg';
---
<div class="grid grid-cols-1 items-center gap-8 sm:grid-cols-2">
  <div>
    <h2 class="font-display text-3xl font-bold tracking-tight">About Me</h2>
    <p class="mt-4 text-(--color-muted)">
      Hi, I'm Muhammed Shah — a developer who enjoys building things end to end
      and writing about what I learn along the way.
    </p>
    <p class="mt-4 text-(--color-muted)">
      This blog is where I keep notes on projects, tools, and the occasional
      rabbit hole worth sharing.
    </p>
  </div>
  <div class="aspect-square overflow-hidden rounded-2xl border border-(--color-border)">
    <Image
      src={profile}
      alt="Muhammed Shah"
      width={600}
      height={600}
      class="h-full w-full object-cover"
    />
  </div>
</div>
