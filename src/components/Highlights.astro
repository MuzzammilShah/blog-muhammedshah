---
const items = [
  {
    title: 'Deep dives',
    description: 'Long-form posts that go beyond the surface on a single topic.',
    icon: 'M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z',
  },
  {
    title: 'Quick notes',
    description: 'Short write-ups on things I want to remember later.',
    icon: 'M6 5h12M6 5v14a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V5M6 5 7 3h10l1 2M9 9h6M9 13h6',
  },
  {
    title: 'Discussions',
    description: 'Thoughts worth talking about — feedback always welcome.',
    icon: 'M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z',
  },
  {
    title: 'New territory',
    description: 'Exploring tools and ideas I haven’t tried before.',
    icon: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm4.2 5.8-2 6-6 2 2-6Z',
  },
];
---
<div class="grid grid-cols-1 divide-y divide-(--color-border) sm:grid-cols-2 sm:divide-x sm:divide-y-0 lg:grid-cols-4">
  {items.map((item) => (
    <div class="grid grid-rows-[auto_auto_1fr] items-start gap-3 px-4 py-6 sm:px-6">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="h-8 w-8 text-(--color-accent)"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
      </svg>
      <h3 class="font-display text-lg font-semibold">{item.title}</h3>
      <p class="text-sm text-(--color-muted)">{item.description}</p>
    </div>
  ))}
</div>
