---
import { getCollection } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  currentId: string;
}

const { currentId } = Astro.props;

const others = (await getCollection('posts', ({ data }) => (import.meta.env.PROD ? !data.draft : true)))
  .filter((post) => post.id !== currentId)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
{others.length > 0 && (
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <h2 class="font-display text-2xl font-semibold">Other articles</h2>
    <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {others.map((post) => <PostCard post={post} />)}
    </div>
    <a
      href="/#posts"
      class="mt-8 inline-flex items-center gap-1 text-sm font-medium text-(--color-accent) hover:text-(--color-accent-hover) transition-colors"
    >
      &larr; Back to all posts
    </a>
  </section>
)}
