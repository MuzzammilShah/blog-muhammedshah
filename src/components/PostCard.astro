---
import { Image } from 'astro:assets';
import PostMeta from './PostMeta.astro';
import { splitInlineCode } from '../lib/inlineCode';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, thumbnail, thumbnailAlt, pubDate, author } = post.data;
const titleParts = splitInlineCode(title);
---
<a
  href={`/posts/${post.id}/`}
  class="group block overflow-hidden border border-(--color-border) bg-(--color-surface) transition-colors hover:border-(--color-fg)/30 hover:shadow-[0_0_0_1px_var(--color-fg)] hover:shadow-(--color-fg)/10"
>
  <div class="aspect-[16/9] overflow-hidden">
    <Image
      src={thumbnail}
      alt={thumbnailAlt}
      width={800}
      height={450}
      class="h-full w-full object-cover"
    />
  </div>
  <div class="p-5">
    <h3 class="font-display text-lg font-semibold leading-snug group-hover:text-(--color-heading-hover) transition-colors">
      {titleParts.map((part) => (part.code ? <code class="font-sans font-normal">{part.value}</code> : part.value))}
    </h3>
    <p class="mt-2 line-clamp-2 text-sm text-(--color-muted)">{description}</p>
    <PostMeta pubDate={pubDate} author={author} class="mt-4" />
  </div>
</a>
