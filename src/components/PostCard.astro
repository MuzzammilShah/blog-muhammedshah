---
import { Image } from 'astro:assets';
import PostMeta from './PostMeta.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, thumbnail, thumbnailAlt, pubDate, author } = post.data;
---
<a
  href={`/posts/${post.id}/`}
  class="group block overflow-hidden rounded-2xl border border-(--color-border) bg-(--color-surface) transition-all hover:-translate-y-1 hover:shadow-lg hover:shadow-black/5"
>
  <div class="aspect-[16/10] overflow-hidden">
    <Image
      src={thumbnail}
      alt={thumbnailAlt}
      width={800}
      height={500}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </div>
  <div class="p-5">
    <h3 class="font-display text-lg font-semibold leading-snug group-hover:text-(--color-accent) transition-colors">
      {title}
    </h3>
    <p class="mt-2 line-clamp-2 text-sm text-(--color-muted)">{description}</p>
    <PostMeta pubDate={pubDate} author={author} class="mt-4" />
  </div>
</a>
